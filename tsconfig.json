  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src",
    "tests",
    "fixtures",
    "helpers",
    "pages",
    "playwright.config.ts",
    "vitest.config.ts"
  ]
}
