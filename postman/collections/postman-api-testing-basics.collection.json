    {
      "name": "GET reuse savedUrl and savedFoo",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test('Response is JSON', function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test('Returned URL contains foo=bar', function () {\r",
              "    pm.expect(jsonData.url).to.include('foo=bar');\r",
              "});\r",
              "\r",
              "pm.test('Returned args.foo matches saved variable', function () {\r",
              "    pm.expect(jsonData.args.foo).to.equal(pm.collectionVariables.get('savedFoo'));\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
