    {
      "name": "GET source",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test('Response is JSON', function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.collectionVariables.set('savedUrl', jsonData.url);\r",
              "pm.collectionVariables.set('savedFoo', jsonData.args.foo);\r",
              "\r",
              "pm.test('savedUrl variable exists', function () {\r",
              "    pm.expect(pm.collectionVariables.get('savedUrl')).to.exist;\r",
              "});\r",
              "\r",
              "pm.test('savedFoo variable exists', function () {\r",
              "    pm.expect(pm.collectionVariables.get('savedFoo')).to.equal('bar');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://postman-echo.com/get?foo=bar",
          "protocol": "https",
          "host": [
            "postman-echo",
            "com"
          ],
          "path": [
