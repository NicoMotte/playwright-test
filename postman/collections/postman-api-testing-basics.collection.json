    {
      "name": "Get data plus savedUrl",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is JSON', function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test('URL is present in response', function () {",
              "    pm.expect(jsonData.url).to.exist;",
              "});",
              "",
              "pm.test('Response time is below 1000 ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "",
              "pm.test('Response time is below 1 ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1);",
              "});",
              "",
              "pm.collectionVariables.set('savedUrl', jsonData.url);"
            ],
