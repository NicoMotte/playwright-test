    {
      "name": "POST postman-echo",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test('Response is JSON', function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.collectionVariables.set('savedUsername', jsonData.data.username);\r",
              "pm.collectionVariables.set('savedRole', jsonData.data.role);\r",
              "\r",
              "pm.test('Username was saved', function () {\r",
              "    pm.expect(pm.collectionVariables.get('savedUsername')).to.equal('Nicolas');\r",
              "});\r",
              "\r",
              "pm.test('Role was saved', function () {\r",
              "    pm.expect(pm.collectionVariables.get('savedRole')).to.equal('tester');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
